    <!-- SCRIPT DE RENDERIZAÇÃO -->
    <script>
    // ============================================
    // RENDERIZAÇÃO DINÂMICA
    // ============================================
    gsap.registerPlugin(ScrollTrigger);

    function renderizar() {
        const d = window.tripData;
        if (!d) return;

        // Título
        document.title = `${d.destino.nome} • ${d.marca.nome}`;

        // Marca
        document.getElementById('nav-marca').textContent = d.marca.nome;
        document.getElementById('footer-marca').textContent = d.marca.nome;
        document.getElementById('footer-slogan').textContent = d.marca.slogan;

        // Hero
        document.getElementById('hero-bg').style.backgroundImage = `url('${d.destino.imagem}')`;
        document.getElementById('hero-label').textContent = d.destino.label;
        document.getElementById('hero-titulo').textContent = d.destino.nome;
        document.getElementById('hero-descricao').textContent = d.destino.descricao;

        // Voos
        const voosContainer = document.getElementById('voos-container');
        voosContainer.innerHTML = `
            <div class="flight-card outbound-card">
                <div class="flight-header">
                    <div class="flight-label">Ida</div>
                    <div class="flight-date">${d.voos.ida.data}</div>
                </div>
                <div class="flight-route-display">
                    <div class="airport">
                        <div class="code">${d.voos.ida.origem_codigo}</div>
                        <div class="city">${d.voos.ida.origem_cidade}</div>
                    </div>
                    <div class="route-arrow">
                        <svg viewBox="0 0 100 40" preserveAspectRatio="none">
