        // Hotéis
        const hoteisContainer = document.getElementById('hoteis-container');
        hoteisContainer.innerHTML = d.hoteis.map(h => {
            const estrelas = '★'.repeat(h.estrelas);
            const destaqueClass = h.destaque ? 'featured' : '';
            const badge = h.badge ? `<div class="hotel-badge">${h.badge}</div>` : '';

            return `
                <div class="hotel-stack-item ${destaqueClass}">
                    ${badge}
                    <div class="hotel-number">${h.numero}</div>
                    <div class="hotel-gallery">
                        <div class="gallery-container" id="gallery-${h.id}">
                            ${h.imagens.map(img => `<div class="gallery-slide" style="background-image: url('${img}')"></div>`).join('')}
                        </div>
                        <div class="gallery-dots" id="dots-${h.id}"></div>
                        <button class="gallery-nav prev" onclick="galleryMove('${h.id}', -1)"><i class="fa-solid fa-chevron-left"></i></button>
                        <button class="gallery-nav next" onclick="galleryMove('${h.id}', 1)"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>
                    <div class="hotel-info">
                        <h3>${h.nome}</h3>
                        <p class="hotel-region"><i class="fa-solid fa-location-dot"></i> ${h.regiao}</p>
                        <div class="hotel-rating">
                            <span class="hotel-stars">${estrelas}</span>
                            <span class="hotel-rating-text">${h.tipo}</span>
                        </div>
                        <p class="hotel-description">${h.descricao}</p>
                        <div class="hotel-amenities">
                            ${h.comodidades.map(c => `<span class="amenity-tag"><i class="fa-solid ${c.icon}"></i> ${c.nome}</span>`).join('')}
                        </div>
                        <div class="hotel-prices">
                            <div class="price-box">
                                <span>Duplo</span>
                                <strong>${h.preco_duplo}</strong>
                            </div>
                            <div class="price-box">
                                <span>Triplo</span>
                                <strong>${h.preco_triplo}</strong>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }).join('');

        // CTA
        const ctaButtons = document.getElementById('cta-buttons');
        ctaButtons.innerHTML = `
            <a href="https://wa.me/${d.marca.whatsapp}" class="btn btn-primary" target="_blank">
                <i class="fa-brands fa-whatsapp"></i> WhatsApp
            </a>
            <a href="mailto:${d.marca.email}" class="btn btn-secondary">
                <i class="fa-solid fa-envelope"></i> Email
            </a>
            <a href="${d.marca.site}" class="btn btn-secondary" target="_blank">
                <i class="fa-solid fa-globe"></i> Site
            </a>
        `;

        // Footer
        const footerLinks = document.getElementById('footer-links');
        footerLinks.innerHTML = `
            <a href="${d.marca.instagram}" target="_blank"><i class="fa-brands fa-instagram"></i></a>
            <a href="https://wa.me/${d.marca.whatsapp}" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
            <a href="${d.marca.site}" target="_blank"><i class="fa-solid fa-globe"></i></a>
        `;

        document.getElementById('footer-copy').textContent = `© ${d.marca.ano} ${d.marca.nome}. Todos os direitos reservados.`;

        // Navbar WhatsApp
        document.getElementById('nav-whatsapp').href = `https://wa.me/${d.marca.whatsapp}`;
    }

    // ============================================
    // GALERIA
    // ============================================
    const galleries = {};

    function initGalerias() {
        document.querySelectorAll('.gallery-container').forEach((container, idx) => {
            const hotelId = container.id.replace('gallery-', '');
            const dots = container.parentElement.querySelector('.gallery-dots');
            const slides = container.querySelectorAll('.gallery-slide');

            if (slides.length > 0) {
                galleries[hotelId] = { current: 0, total: slides.length, slides, dotsContainer: dots };
                if (dots) {
                    dots.innerHTML = '';
                    for (let i = 0; i < slides.length; i++) {
                        const dot = document.createElement('div');
                        dot.className = `dot ${i === 0 ? 'active' : ''}`;
                        dot.onclick = () => goToSlide(hotelId, i);
                        dots.appendChild(dot);
                    }
                }
                updateGallery(hotelId);
            }
        });
    }

    function galleryMove(id, dir) {
        if (!galleries[id]) return;
        const g = galleries[id];
        g.current = (g.current + dir + g.total) % g.total;
        updateGallery(id);
    }

    function goToSlide(id, idx) {
        if (!galleries[id]) return;
        galleries[id].current = idx;
        updateGallery(id);
    }

    function updateGallery(id) {
        const g = galleries[id];
        g.slides.forEach((s, i) => s.classList.toggle('active', i === g.current));
        if (g.dotsContainer) {
            g.dotsContainer.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === g.current));
        }
    }

    function autoAdvanceGalerias() {
        Object.keys(galleries).forEach((id, idx) => {
            setInterval(() => galleryMove(id, 1), 5000 + idx * 1500);
        });
    }

    // ============================================
    // TYPEWRITER
    // ============================================
    const typewriterTexts = ['Disponível agora', 'Atendimento 24h', 'Consulte já!'];
    let textIdx = 0, charIdx = 0, isDeleting = false;
    const typewriterEl = document.getElementById('typewriter-content');

    function typeWriter() {
        if (!typewriterEl) return;
        const txt = typewriterTexts[textIdx];
        typewriterEl.textContent = isDeleting ? txt.substring(0, charIdx - 1) : txt.substring(0, charIdx + 1);
        charIdx = isDeleting ? charIdx - 1 : charIdx + 1;

        if (!isDeleting && charIdx === txt.length) {
            setTimeout(() => isDeleting = true, 2000);
        } else if (isDeleting && charIdx === 0) {
            isDeleting = false;
            textIdx = (textIdx + 1) % typewriterTexts.length;
        }
        setTimeout(typeWriter, isDeleting ? 50 : 100);
    }

    // ============================================
    // CANVAS PROTOCOLO
    // ============================================
    function drawProtocolCanvas() {
        const canvas = document.getElementById('protocol-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, 280, 180);

        const points = [{x: 40, y: 90}, {x: 120, y: 50}, {x: 200, y: 90}, {x: 240, y: 130}];
        ctx.beginPath();
        ctx.moveTo(points[0].x, points[0].y);
        points.forEach(p => ctx.lineTo(p.x, p.y));
        ctx.strokeStyle = '#48B5A0';
        ctx.lineWidth = 2;
        ctx.setLineDash([4, 4]);
        ctx.stroke();

        points.forEach((p, i) => {
            ctx.beginPath();
            ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
            ctx.fillStyle = i === 2 ? '#48B5A0' : '#E8896F';
            ctx.fill();
            ctx.strokeStyle = '#0F4C5C';
            ctx.lineWidth = 2;
            ctx.setLineDash([]);
            ctx.stroke();
        });
    }

    // ============================================
    // ANIMAÇÕES GSAP
    // ============================================
    function initAnimations() {
        const navbar = document.querySelector('.navbar');
        if (navbar) {
            window.addEventListener('scroll', () => {
                const scrolled = window.scrollY > 50;
                navbar.style.top = scrolled ? '10px' : '20px';
                navbar.style.transform = `translateX(-50%) scale(${scrolled ? 0.95 : 1})`;
            });
        }

        gsap.from('.hero-label, .hero-title, .hero-subtitle, .hero-cta', {
            y: -20, opacity: 0, duration: 0.6, stagger: 0.15, ease: 'power2.out'
        });

        gsap.to('.scroll-indicator', { opacity: 0, duration: 0.6, scrollTrigger: { trigger: '.hero', start: '70% top', scrub: true }});

        gsap.from('.flight-card, .duration-card', {
            y: 30, opacity: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out',
            scrollTrigger: { trigger: '.section-flights', start: 'top 75%' }
        });

        gsap.from('.philosophy-intro, .philosophy-contrast', {
            y: 40, opacity: 0, duration: 0.9, stagger: 0.2,
            scrollTrigger: { trigger: '.section-philosophy', start: 'top 65%' }
        });

        gsap.from('.feature-card', {
            y: 30, opacity: 0, duration: 0.5, stagger: 0.1, ease: 'power2.out',
            scrollTrigger: { trigger: '.section-features', start: 'top 75%' }
        });

        gsap.from('.hotel-stack-item', {
            y: 40, opacity: 0, duration: 0.7, stagger: 0.2, ease: 'power2.out',
            scrollTrigger: { trigger: '.section-hotels', start: 'top 75%' }
        });

        gsap.from('.section-cta h2, .section-cta p, .btn', {
            y: 40, opacity: 0, duration: 0.8, stagger: 0.15,
            scrollTrigger: { trigger: '.section-cta', start: 'top 75%' }
        });

        gsap.from('.footer', {
            y: 30, opacity: 0, duration: 0.8,
            scrollTrigger: { trigger: '.footer', start: 'top 95%' }
        });
    }

    // ============================================
    // SMOOTH SCROLL
    // ============================================
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
            const href = a.getAttribute('href');
            if (href !== '#') {
                e.preventDefault();
                document.querySelector(href)?.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });

    // ============================================
    // INICIALIZAÇÃO
    // ============================================
    document.addEventListener('DOMContentLoaded', () => {
